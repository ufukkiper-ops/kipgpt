# Gmail / Outlook / Yahoo OAuth (şifresiz) giriş — varsayılan kapalı
# OAUTH_LOGIN_ENABLED=1

# OpenAI
OPENAI_API_KEY=
# Varsayılan: gpt-4.1 (en güncel GPT). İsterseniz gpt-4o, o3-mini vb. yazın.
OPENAI_MODEL=gpt-4.1

# Flask (production'da güçlü rastgele değer zorunlu)
# SECRET_KEY veya FLASK_SECRET_KEY (ikisi de okunur)
FLASK_SECRET_KEY=gizli123
# SECRET_KEY=
# İsteğe bağlı: mail şifre/token şifreleme anahtarı (yoksa FLASK_SECRET_KEY'den türetilir)
# MAIL_CREDENTIALS_KEY=

# Kalıcı veri (Render disk: KIPGPT_DATA_DIR=/var/data)
# KIPGPT_DATA_DIR=

# Telefondan / dışarıdan erişim tabanı (OAuth yönlendirme)
# LAN:  http://192.168.x.x:5001
# Tunnel (start_public.bat): https://xxxx.trycloudflare.com  veya sabit domain
# PUBLIC_BASE_URL=http://127.0.0.1:5001

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Giriş/kayıt callback
# Yerel: http://127.0.0.1:5001/auth/google/callback
# Render: https://kip-asistan.onrender.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:5001/auth/google/callback
# Mail hesabı bağlama callback (Google Console'a da ekleyin)
# Yerel: http://127.0.0.1:5001/mail/oauth/google/callback
# Render: https://kip-asistan.onrender.com/mail/oauth/google/callback
GOOGLE_MAIL_REDIRECT_URI=http://127.0.0.1:5001/mail/oauth/google/callback

# Microsoft / Outlook OAuth (Azure App Registration)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Yerel: http://127.0.0.1:5001/mail/oauth/microsoft/callback
# Render: https://kip-asistan.onrender.com/mail/oauth/microsoft/callback
MICROSOFT_REDIRECT_URI=http://127.0.0.1:5001/mail/oauth/microsoft/callback

# Yahoo Mail OAuth (Yahoo Developer Network)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
# Yerel: http://127.0.0.1:5001/mail/oauth/yahoo/callback
# Render: https://kip-asistan.onrender.com/mail/oauth/yahoo/callback
YAHOO_REDIRECT_URI=http://127.0.0.1:5001/mail/oauth/yahoo/callback

# Sistem e-posta (şifre sıfırlama kodları) — Gmail uygulama şifresi önerilir
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
